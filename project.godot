; Engine configuration file — "The City" (Godot 2.5D isometric frontend).
; Godot 4.3 · GDScript · GL Compatibility renderer (required for a robust HTML5
; web export, PRD §12 / §13). Autoloads are the ENTIRE shared runtime surface
; (PRD §12.1) — the small-surface architecture that keeps GDScript ramp-up cheap.
;
; Edited by hand for the F0 skeleton. Open in Godot 4.3+ to smoke-test.

config_version=5

[application]

config/name="The City"
config/description="WarRoom City — the 2.5D isometric training city (F0 skeleton)."
run/main_scene="res://main/boot.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

; Order matters: EventBus first (everyone connects to it), then the rest.
; AppConfig is intentionally NOT an autoload — it is a static class_name so it
; carries no state and cannot drift. That keeps the shared surface at 7 (PRD §12.1).
EventBus="*res://autoload/event_bus.gd"
ApiClient="*res://autoload/api_client.gd"
Session="*res://autoload/session.gd"
PlayerState="*res://autoload/player_state.gd"
Economy="*res://autoload/economy.gd"
SceneRouter="*res://autoload/scene_router.gd"
AudioManager="*res://autoload/audio_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=0
window/size/resizable=true
; Minimum viewport 1280x720 (PRD §5.4); scale the canvas, keep aspect.
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/size/window_width_override=1280
window/size/window_height_override=720

[dotnet]

project/assembly_name="The City"

[input]

