# ── The City — F0 configuration ──────────────────────────────────────────────
# Copy to `.env` (gitignored) and fill in. The Firebase WEB API key is a client
# identifier (it ships in every web bundle), NOT a secret — but we never commit a
# value we weren't given. Leave it blank and the login screen shows a clear
# "configuration missing" message instead of failing cryptically.
#
# WEB CONSTRAINT: Vite only exposes vars prefixed with VITE_ or NEXT_PUBLIC_ to
# the client. Use those prefixes. The main WarRoom frontend's NEXT_PUBLIC_* .env
# can be dropped in verbatim (PRD §10). Resolution order (last wins):
#   baked defaults  <  .env (VITE_* / NEXT_PUBLIC_*)  <  window.__CITY_CONFIG__

# Firebase web API key (from the main frontend's build config). REQUIRED for login.
VITE_FIREBASE_API_KEY=

# Firebase project id (default: warroom-498513).
VITE_FIREBASE_PROJECT_ID=warroom-498513

# Backend base URL — http://localhost:8080 for local dev, or the live Cloud Run
# origin. A trailing "/api" is stripped automatically (academy routes are at
# /api/v1 off root; the main frontend's NEXT_PUBLIC_API_URL ends in /api).
VITE_API_BASE_URL=http://localhost:8080

# Where unknown users go to sign up (the backend never returns a redirectUrl).
VITE_REGISTER_URL=https://warroom.humanfirstbykk.com/register

# Set to 1 to bypass Firebase with a dev-only mock session (CI / e2e / offline
# dev). NEVER set in production. Leave blank for the real Firebase login path.
VITE_CITY_MOCK_AUTH=
