# The City · web frontend environment — copy to .env and fill in real values.
#   cp .env.example .env
# .env is gitignored. Vite exposes only VITE_* and NEXT_PUBLIC_* vars to the app
# (see envPrefix in vite.config.ts), resolved centrally in
# src/framework/config/appConfig.ts.

# Firebase *web* API key (project warroom-498513). A client identifier, not a
# secret — but kept out of the repo. Sign-in is disabled until this is set.
VITE_FIREBASE_API_KEY=

# Firebase project id (defaults to warroom-498513) and backend base URL. A
# trailing "/api" is stripped automatically (academy routes are /api/v1 off root).
VITE_FIREBASE_PROJECT_ID=warroom-498513
VITE_API_BASE_URL=http://localhost:8080

# Where an unregistered WarRoom user is sent to sign up (PRD §10).
VITE_REGISTER_URL=https://warroom.humanfirstbykk.com/register

# The main WarRoom frontend's NEXT_PUBLIC_* names are ALSO accepted, so its .env
# drops in verbatim (the canonical VITE_* name wins if both are present):
#   NEXT_PUBLIC_FIREBASE_API_KEY, NEXT_PUBLIC_FIREBASE_PROJECT_ID, NEXT_PUBLIC_API_URL
