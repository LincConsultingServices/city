# The City · frontend environment — copy to .env and fill in real values.
#   cp .env.example .env
# .env is gitignored. Format matches the backend's godotenv convention
# (KEY=VALUE, '#' comments, optional surrounding quotes). Real OS environment
# variables of the same name override this file (the CI path).

# Firebase *web* API key (project warroom-498513). A client identifier, not a
# secret — but kept out of the repo. Take it from the main frontend's build
# config (PRD §10). Login is disabled until this is set.
FIREBASE_API_KEY=

# Firebase project id. Defaults to warroom-498513; override only if needed.
FIREBASE_PROJECT_ID=warroom-498513

# Backend base URL (no trailing slash). Local dev default is localhost:8080;
# set the Cloud Run URL per deployed build.
API_BASE_URL=http://localhost:8080

# Where an unregistered WarRoom user is sent to sign up (PRD §10). The backend
# never returns a redirectUrl, so the client owns this value.
REGISTER_URL=https://warroom.humanfirstbykk.com/register
